# Zyvex AI Platform — Environment Variables
# Copy this file to .env.local and fill in your values

# Anthropic API Key (for direct browser streaming)
# Get yours at: https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Backend API URL (optional - for proxy mode)
VITE_API_URL=https://api.your-backend.com/v1
